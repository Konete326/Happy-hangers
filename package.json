{
  "name": "happy-hanger",
  "version": "1.0.3",
  "description": "Happy Hangers Premium POS System",
  "main": "main.js",
  "scripts": {
    "dev:client": "npm run dev --prefix client",
    "dev:server": "npm run dev --prefix server",
    "dev:electron": "cross-env WAIT_ON_TIMEOUT=60000 wait-on http://localhost:5173 && electron .",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:electron\"",
    "build:client": "npm run build --prefix client",
    "build:server": "npm install --prefix server",
    "prebuild": "node process-icon.js && node inject-env.js",
    "build": "npm run build:client && npm run build:server && electron-builder --win"
  },
  "build": {
    "appId": "com.elitedevagency.happyhanger",
    "productName": "Happy Hangers",
    "directories": {
      "buildResources": "build",
      "output": "dist_installer"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "Happy Hangers",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "elitedevagency",
        "repo": "Happy-hangers"
      }
    ],
    "files": [
      "main.js",
      "server/**/*",
      "client/dist/**/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elitedevagency/Happy-hangers.git"
  },
  "author": "elitedevagency",
  "license": "MIT",
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.10"
  }
}